{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Janaushadhi Store - Chirag Singhal's Jan Aushadhi Kendra",
  "short_name": "Janaushadhi",
  "description": "Unofficial Janaushadhi store website for Chirag Singhal's Jan Aushadhi Kendra in Bhubaneswar. Browse 2,400+ generic medicines, check prices, and place orders.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#1a5276",
  "orientation": "portrait-primary",
  "categories": ["shopping", "health", "medical"],
  "lang": "en-IN",
  "dir": "ltr",
  "id": "/?source=pwa",
  "scope": "/",
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/mobile-1.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Medicine listing page on mobile"
    },
    {
      "src": "/screenshots/desktop-1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Medicine catalogue on desktop"
    }
  ],
  "shortcuts": [
    {
      "name": "Search Medicines",
      "url": "/search",
      "description": "Search for medicines",
      "icons": [{ "src": "/icons/search.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "View Cart",
      "url": "/cart",
      "description": "View your shopping cart",
      "icons": [{ "src": "/icons/cart.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Track Orders",
      "url": "/orders",
      "description": "Track your orders",
      "icons": [{ "src": "/icons/orders.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "related_applications": [],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
