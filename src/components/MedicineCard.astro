---
// src/components/MedicineCard.astro
//
// Medicine card component for grid and list views
// Shows: Generic name, drug code, unit size, MRP, category badge

interface Props {
  medicine: {
    id: number;
    drugCode: string;
    genericName: string;
    unitSize: string;
    mrp: number;
    groupName: string;
    slug: string;
    isPriceOnRequest: boolean;
    priceDisplay: string;
  };
  variant?: 'grid' | 'list' | 'compact';
  showCategory?: boolean;
}

const { medicine, variant = 'grid', showCategory = true } = Astro.props;
---

<article class={`medicine-card medicine-card--${variant}`}>
  <a href={`/medicines/${medicine.slug}`} class="medicine-card-link" data-astro-prefetch>
    <div class="medicine-card-content">
      <!-- Medicine Name -->
      <h3 class="medicine-name" title={medicine.genericName}>
        {medicine.genericName}
      </h3>

      <!-- Drug Code & Unit -->
      <div class="medicine-meta">
        <span class="drug-code" title="Drug Code">{medicine.drugCode}</span>
        <span class="unit-size">{medicine.unitSize}</span>
      </div>

      <!-- Category Badge (optional) -->
      {showCategory && medicine.groupName && (
        <span class="category-badge">{medicine.groupName}</span>
      )}

      <!-- Price -->
      <div class="medicine-price-wrapper">
        <span class={`medicine-price ${medicine.isPriceOnRequest ? 'price-on-request' : ''}`}>
          {medicine.priceDisplay}
        </span>
        {medicine.isPriceOnRequest && (
          <span class="price-notice">Contact for price</span>
        )}
      </div>

      <!-- Quick actions -->
      <div class="card-actions">
        <button class="add-to-cart-btn" title="Add to cart" data-medicine={JSON.stringify(medicine)} onclick="event.preventDefault(); addToCart(this.dataset.medicine)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          Add
        </button>
        <button class="wishlist-btn" title="Add to wishlist" onclick={`event.preventDefault(); toggleWishlist('${medicine.slug}')`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
      </div>
    </div>
  </a>
</article>

<style>
  .medicine-card {
    background-color: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-out);
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .medicine-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--color-primary-200), transparent);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--duration-normal);
    pointer-events: none;
  }

  .medicine-card:hover::before,
  .medicine-card:focus-within::before {
    opacity: 1;
  }

  .medicine-card:hover,
  .medicine-card:focus-within {
    border-color: var(--color-primary-200);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    transform: translateY(-4px);
  }

  [data-theme="dark"] .medicine-card:hover,
  [data-theme="dark"] .medicine-card:focus-within {
    border-color: var(--color-primary-600);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), 0 0 20px rgba(26, 82, 118, 0.2);
  }

  .medicine-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-5);
    color: inherit;
    text-decoration: none;
    transition: all var(--duration-fast);
  }

  .medicine-card-link:active {
    transform: scale(0.98);
  }

  .medicine-card-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-3);
  }

  .medicine-name {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.8em;
    transition: color var(--duration-fast);
  }

  .medicine-card:hover .medicine-name {
    color: var(--color-primary-600);
  }

  [data-theme="dark"] .medicine-card:hover .medicine-name {
    color: var(--color-primary-300);
  }

  .medicine-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .drug-code {
    font-family: var(--font-mono);
    background: linear-gradient(135deg, var(--color-grey-100), var(--color-grey-50));
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    font-size: 0.7rem;
    border: 1px solid var(--color-border);
  }

  [data-theme="dark"] .drug-code {
    background: linear-gradient(135deg, var(--color-grey-800), var(--color-grey-700));
    color: var(--color-grey-300);
    border-color: var(--color-border);
  }

  .unit-size {
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
  }

  .category-badge {
    display: inline-block;
    font-size: var(--text-xs);
    color: var(--color-primary-600);
    background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100));
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-md);
    align-self: flex-start;
    font-weight: var(--font-medium);
    border: 1px solid transparent;
    transition: all var(--duration-fast);
  }

  .medicine-card:hover .category-badge {
    border-color: var(--color-primary-200);
    background: linear-gradient(135deg, var(--color-primary-100), var(--color-primary-50));
  }

  [data-theme="dark"] .category-badge {
    color: var(--color-primary-300);
    background: linear-gradient(135deg, rgba(26, 82, 118, 0.3), rgba(26, 82, 118, 0.2));
  }

  [data-theme="dark"] .medicine-card:hover .category-badge {
    border-color: var(--color-primary-500);
  }

  .medicine-price-wrapper {
    margin-top: auto;
    padding-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .medicine-price {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-primary-600);
    letter-spacing: -0.02em;
  }

  .medicine-price.price-on-request {
    color: var(--color-accent-600);
    font-size: var(--text-base);
  }

  .price-notice {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-style: italic;
  }

  .card-actions {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
    opacity: 0;
    transform: translateY(4px);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .medicine-card:hover .card-actions {
    opacity: 1;
    transform: translateY(0);
  }

  .add-to-cart-btn,
  .wishlist-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    transition: all var(--duration-fast) var(--ease-out);
    flex: 1;
    border: 1px solid transparent;
  }

  .add-to-cart-btn {
    background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-700));
    color: white;
    box-shadow: 0 2px 4px rgba(26, 82, 118, 0.2);
  }

  .add-to-cart-btn:hover {
    background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600));
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(26, 82, 118, 0.3);
  }

  .wishlist-btn {
    background-color: var(--color-grey-100);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  [data-theme="dark"] .wishlist-btn {
    background-color: var(--color-grey-800);
    color: var(--color-text-secondary);
    border-color: var(--color-border);
  }

  .wishlist-btn:hover {
    background-color: var(--color-error-light);
    color: var(--color-error);
    border-color: var(--color-error-light);
    transform: translateY(-1px);
  }

  /* Grid vs List variants */
  .medicine-card--list {
    flex-direction: row;
    align-items: center;
  }

  .medicine-card--list .medicine-card-content {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .medicine-card--list .medicine-name {
    flex: 1;
    min-width: 200px;
    min-height: auto;
    -webkit-line-clamp: 1;
  }

  .medicine-card--list .medicine-price-wrapper {
    padding-top: 0;
    min-width: 120px;
    text-align: right;
  }

  .medicine-card--list .card-actions {
    margin-top: 0;
  }

  /* Compact variant */
  .medicine-card--compact .medicine-card-content {
    gap: var(--space-1);
  }

  .medicine-card--compact .medicine-name {
    font-size: var(--text-sm);
    -webkit-line-clamp: 2;
  }

  .medicine-card--compact .card-actions {
    display: none;
  }

  @media (max-width: 640px) {
    .card-actions {
      display: flex !important;
      opacity: 1 !important;
      transform: none !important;
    }

    .add-to-cart-btn::after {
      content: 'Add';
    }

    .medicine-card {
      border-radius: var(--radius-lg);
    }
  }

  /* Animation for add to cart feedback */
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .add-to-cart-btn:active {
    animation: pulse 0.3s ease;
  }
</style>

<script is:inline>
  // Quick add to cart from card
  function addToCart(medicineData) {
    try {
      const medicine = typeof medicineData === 'string' ? JSON.parse(medicineData) : medicineData;
      const cart = JSON.parse(localStorage.getItem('janaushadhi-cart') || '[]');
      const existing = cart.find(item => item.slug === medicine.slug);

      if (existing) {
        existing.quantity += 1;
      } else {
        cart.push({ 
          slug: medicine.slug, 
          quantity: 1,
          genericName: medicine.genericName,
          mrp: medicine.mrp,
          isPriceOnRequest: medicine.isPriceOnRequest,
          unitSize: medicine.unitSize,
          drugCode: medicine.drugCode
        });
      }

      localStorage.setItem('janaushadhi-cart', JSON.stringify(cart));
      updateCartCount();
      showToast('Added to cart');
    } catch (e) {
      console.error('Failed to parse medicine data', e);
    }
  }

  function toggleWishlist(slug) {
    let wishlist = JSON.parse(localStorage.getItem('janaushadhi-wishlist') || '[]');

    if (wishlist.includes(slug)) {
      wishlist = wishlist.filter(item => item !== slug);
      showToast('Removed from wishlist');
    } else {
      wishlist.push(slug);
      showToast('Added to wishlist');
    }

    localStorage.setItem('janaushadhi-wishlist', JSON.stringify(wishlist));
  }

  function updateCartCount() {
    const cart = JSON.parse(localStorage.getItem('janaushadhi-cart') || '[]');
    const count = cart.reduce((sum, item) => sum + item.quantity, 0);
    const badge = document.getElementById('cart-count');

    if (badge) {
      badge.textContent = count;
      badge.classList.toggle('visible', count > 0);
    }
  }

  function showToast(message) {
    // Create toast element
    const toast = document.createElement('div');
    toast.textContent = message;
    toast.style.cssText = `
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--color-grey-800);
      color: white;
      padding: 12px 24px;
      border-radius: var(--radius-lg);
      font-size: var(--text-sm);
      z-index: 9999;
      animation: fadeInUp 0.3s ease;
    `;
    document.body.appendChild(toast);

    setTimeout(() => {
      toast.remove();
    }, 2000);
  }

  // Update cart count on page load
  document.addEventListener('DOMContentLoaded', updateCartCount);
</script>
