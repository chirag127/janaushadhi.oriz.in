---
// src/pages/contact.astro
// Contact page with store details and simple form

import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact Us | Chirag Singhal\'s Janaushadhi Kendra';
const description = 'Get in touch with Chirag Singhal\'s Jan Aushadhi Kendra in Bhubaneswar. Call +91 74284 44970 or email hi@janaushadhi.oriz.in';
---

<BaseLayout title={title} description={description} url="/contact">
  <main class="contact-page">
    <div class="container">
      <header class="page-header">
        <h1>Contact Us</h1>
        <p class="lead">We're here to help. Reach out anytime.</p>
      </header>

      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info-section">
          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="info-content">
              <h3>Store Address</h3>
              <p>
                Plot #448, Niladri Vihar, Lane 5, Sector 5<br/>
                Chandrasekharpur, Bhubaneswar<br/>
                Odisha - 751021
              </p>
              <a
                href="https://maps.google.com/?q=Plot+448+Niladri+Vihar+Lane5+Sector5+Chandrasekharpur+Bhubaneswar+751021"
                target="_blank"
                rel="noopener"
                class="map-link"
              >
                View on Google Maps
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div class="info-content">
              <h3>Phone</h3>
              <p>
                <a href="tel:+917428449707">+91 74284 44970</a>
              </p>
              <p class="note">Available 24/7</p>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="info-content">
              <h3>Email</h3>
              <p>
                <a href="mailto:hi@janaushadhi.oriz.in">hi@janaushadhi.oriz.in</a>
              </p>
              <p class="note">Quick response guaranteed</p>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="info-content">
              <h3>Working Hours</h3>
              <p>
                Open 24 hours a day<br/>
                All days of the week
              </p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-section">
          <div class="form-card">
            <h2>Send Us a Message</h2>

            <form id="contact-form" class="contact-form">
              <div class="form-group">
                <label for="contact-name">Your Name *</label>
                <input type="text" id="contact-name" name="name" required />
              </div>

              <div class="form-group">
                <label for="contact-phone">Phone Number *</label>
                <input type="tel" id="contact-phone" name="phone" required />
              </div>

              <div class="form-group">
                <label for="contact-email">Email *</label>
                <input type="email" id="contact-email" name="email" required />
              </div>

              <div class="form-group">
                <label for="contact-subject">Subject</label>
                <input type="text" id="contact-subject" name="subject" placeholder="e.g., Medicine inquiry, order status" />
              </div>

              <div class="form-group">
                <label for="contact-message">Message *</label>
                <textarea id="contact-message" name="message" rows="5" required></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-lg btn-block" id="contact-submit-btn">
                Send Message
              </button>
            </form>

            <div id="form-feedback" class="feedback-message" style="display: none;"></div>
          </div>

          <!-- WhatsApp CTA -->
          <div class="whatsapp-cta">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div>
              <h4>WhatsApp Orders</h4>
              <p>Prefer WhatsApp? Send your order directly.</p>
              <a href="https://wa.me/917428449707" target="_blank" rel="noopener" class="btn btn-whatsapp">
                Chat on WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Map placeholder -->
      <div class="map-section">
        <h2>Find Us</h2>
        <div class="map-container">
          <iframe
            src="https://maps.google.com/maps?q=Plot+448+Niladri+Vihar+Lane5+Sector5+Chandrasekharpur+Bhubaneswar+751021&t=&z=13&ie=UTF8&iwloc=&output=embed"
            width="100%"
            height="400"
            style="border:0; border-radius: var(--radius-xl);"
            allowfullscreen=""
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </main>

  <script is:client>
    document.getElementById('contact-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();

      const form = e.target;
      const submitBtn = document.getElementById('contact-submit-btn');
      const feedback = document.getElementById('form-feedback');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        // Using EmailJS to send contact message
        await emailjs.send(
          import.meta.env.EMAILJS_SERVICE_ID,
          import.meta.env.EMAILJS_TEMPLATE_ID,
          {
            name: form.name.value,
            phone: form.phone.value,
            email: form.email.value,
            subject: form.subject.value || 'Contact Form Message',
            message: form.message.value
          },
          import.meta.env.EMAILJS_PUBLIC_KEY
        );

        feedback.style.display = 'block';
        feedback.className = 'feedback-message success';
        feedback.innerHTML = `
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          Message sent successfully! We'll get back to you soon.
        `;
        form.reset();
      } catch (error) {
        feedback.style.display = 'block';
        feedback.className = 'feedback-message error';
        feedback.innerHTML = `
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          Failed to send message. Please try again or call us directly.
        `;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  </script>

  <style is:global>
    .contact-page {
      padding: var(--space-8) 0 var(--space-16);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    @media (min-width: 1024px) {
      .contact-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .info-card {
      display: flex;
      gap: var(--space-4);
      padding: var(--space-6);
      background-color: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      margin-bottom: var(--space-4);
    }

    .info-icon {
      flex-shrink: 0;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: var(--color-primary-100);
      color: var(--color-primary-600);
      border-radius: var(--radius-lg);
    }

    [data-theme="dark"] .info-icon {
      background-color: var(--color-primary-900);
      color: var(--color-primary-300);
    }

    .info-content h3 {
      font-size: var(--text-lg);
      margin-bottom: var(--space-2);
    }

    .info-content p {
      color: var(--color-text-secondary);
      line-height: var(--leading-relaxed);
      margin: 0;
    }

    .info-content a {
      color: var(--color-primary-600);
    }

    .info-content .note {
      font-size: var(--text-sm);
      color: var(--color-text-tertiary);
      margin-top: var(--space-1);
    }

    .map-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-1);
      margin-top: var(--space-2);
      font-size: var(--text-sm);
      font-weight: var(--font-medium);
    }

    /* Form */
    .form-card {
      background-color: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
    }

    .form-card h2 {
      font-size: var(--text-xl);
      margin-bottom: var(--space-6);
    }

    .form-group {
      margin-bottom: var(--space-4);
    }

    .form-group label {
      display: block;
      font-size: var(--text-sm);
      font-weight: var(--font-medium);
      margin-bottom: var(--space-2);
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: var(--space-3);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      font-size: var(--text-base);
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--color-primary-500);
    }

    .feedback-message {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-4);
      border-radius: var(--radius-lg);
      margin-top: var(--space-4);
      font-size: var(--text-sm);
    }

    .feedback-message.success {
      background-color: var(--color-success-light);
      color: var(--color-success-dark);
    }

    .feedback-message.error {
      background-color: var(--color-error-light);
      color: var(--color-error-dark);
    }

    /* WhatsApp CTA */
    .whatsapp-cta {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      margin-top: var(--space-6);
      padding: var(--space-6);
      background-color: #25D366;
      background: linear-gradient(135deg, #25D366, #128C7E);
      border-radius: var(--radius-xl);
      color: white;
    }

    .whatsapp-cta h4 {
      margin-bottom: var(--space-1);
      font-size: var(--text-lg);
    }

    .whatsapp-cta p {
      font-size: var(--text-sm);
      opacity: 0.9;
      margin-bottom: var(--space-2);
    }

    .whatsapp-cta .btn {
      background-color: white;
      color: #128C7E;
      padding: var(--space-2) var(--space-4);
      display: inline-flex;
    }

    .whatsapp-cta .btn:hover {
      background-color: #f0f0f0;
    }

    /* Map */
    .map-section {
      margin-top: var(--space-12);
    }

    .map-section h2 {
      font-size: var(--text-2xl);
      margin-bottom: var(--space-6);
    }

    .map-container {
      border-radius: var(--radius-xl);
      overflow: hidden;
    }
  </style>
</BaseLayout>
