---
// src/pages/disclaimer.astro
// Unofficial Store Disclaimer

import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Disclaimer | Unofficial Janaushadhi Store';
const description = 'Important disclaimer: This is an unofficial Janaushadhi store website not affiliated with the Government of India or BPPI.';
---

<BaseLayout title={title} description={description} url="/disclaimer">
  <main class="legal-page">
    <div class="container">
      <article class="legal-content">
        <header class="legal-header">
          <h1>Disclaimer</h1>
        </header>

        <div class="disclaimer-hero">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          <h2>Unofficial Website</h2>
          <p class="lead">This website is not affiliated with the Government of India or BPPI</p>
        </div>

        <section>
          <h2>Important Notice</h2>
          <p>
            <strong>Janaushadhi Store</strong> (<a href="https://janaushadhi.oriz.in">janaushadhi.oriz.in</a>)
            is an <strong>independent, unofficial website</strong> operated by Chirag Singhal.
            We are <strong>NOT</strong> affiliated with, endorsed by, or connected to:
          </p>
          <ul>
            <li>The Government of India</li>
            <li>BPPI (Bureau of Pharma PSUs of India)</li>
            <li>The official Janaushadhi programme (janaushadhi.gov.in)</li>
          </ul>
        </section>

        <section>
          <h2>Official Source</h2>
          <p>
            For official information about Janaushadhi medicines, prices, and the programme,
            please visit the government portal:
          </p>
          <p>
            <a href="https://janaushadhi.gov.in" target="_blank" rel="noopener">
              https://janaushadhi.gov.in
            </a>
          </p>
        </section>

        <section>
          <h2>Our Affiliation</h2>
          <p>
            We are a <strong>retailer</strong> of Janaushadhi generic medicines. We purchase
            products through authorized distributors and sell them to customers in Bhubaneswar.
            This website is simply a digital catalogue and ordering platform for our store.
          </p>
        </section>

        <section>
          <h2>Trademarks</h2>
          <p>
            "Janaushadhi" and related logos are trademarks of the Government of India/BPPI.
            Use of these marks on this website is for informational purposes only to indicate
            the products we carry. We do not claim ownership of these trademarks.
          </p>
        </section>

        <section>
          <h2>Pricing Accuracy</h2>
          <p>
            While we strive to maintain accurate pricing, prices shown on this website may differ
            from actual store prices due to market fluctuations. "Price on Request" items require
            confirmation at time of order.
          </p>
        </section>

        <section>
          <h2>Contact</h2>
          <p>
            For questions about this website or our store, contact:
          </p>
          <ul>
            <li>Email: <a href="mailto:hi@janaushadhi.oriz.in">hi@janaushadhi.oriz.in</a></li>
            <li>Phone: <a href="tel:+917428449707">+91 74284 49707</a></li>
          </ul>
        </section>
      </article>
    </div>
  </main>

  <style is:global>
    .legal-page {
      padding: var(--space-8) 0 var(--space-16);
    }

    .legal-content {
      max-width: 800px;
      margin: 0 auto;
      background-color: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-8);
    }

    .legal-header {
      margin-bottom: var(--space-6);
    }

    .disclaimer-hero {
      text-align: center;
      padding: var(--space-8);
      margin-bottom: var(--space-8);
      background: linear-gradient(135deg, var(--color-warning-light), var(--color-warning-100));
      border-radius: var(--radius-xl);
    }

    [data-theme="dark"] .disclaimer-hero {
      background: linear-gradient(135deg, rgba(255, 193, 7, 0.15), rgba(255, 193, 7, 0.25));
    }

    .disclaimer-hero svg {
      margin-bottom: var(--space-4);
    }

    .disclaimer-hero h2 {
      font-size: var(--text-2xl);
      color: var(--color-warning-dark);
      margin-bottom: var(--space-2);
    }

    [data-theme="dark"] .disclaimer-hero h2 {
      color: var(--color-warning-200);
    }

    .disclaimer-hero .lead {
      font-size: var(--text-lg);
      color: var(--color-warning-dark);
    }

    section {
      margin-bottom: var(--space-8);
    }

    h2 {
      font-size: var(--text-xl);
      margin-bottom: var(--space-4);
      color: var(--color-primary-600);
    }

    .lead {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
    }

    p {
      margin-bottom: var(--space-4);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
    }

    ul {
      margin-bottom: var(--space-4);
      padding-left: var(--space-6);
    }

    li {
      margin-bottom: var(--space-2);
    }

    a {
      color: var(--color-primary-600);
    }
  </style>
</BaseLayout>
