---
// src/pages/refund-policy.astro
// Refund/Return Policy

import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Refund Policy | Janaushadhi Store';
const description = 'Refund and return policy for orders placed at Janaushadhi Store.';
---

<BaseLayout title={title} description={description} url="/refund-policy">
  <main class="legal-page">
    <div class="container">
      <article class="legal-content">
        <header class="legal-header">
          <h1>Refund & Return Policy</h1>
          <p class="last-updated">Last updated: {new Date().toLocaleDateString()}</p>
        </header>

        <section>
          <h2>1. General Policy</h2>
          <p>
            Due to the sensitive nature of pharmaceutical products, we have a strict no-return
            policy for most items. However, we understand that issues can arise, and we will
            consider refund requests on a case-by-case basis.
          </p>
        </section>

        <section>
          <h2>2. Eligible Returns</h2>
          <p>We accept returns and issue refunds only in the following circumstances:</p>
          <ul>
            <li><strong>Damaged/Defective Products:</strong> Seal broken, packaging damaged, or product appears tampered</li>
            <li><strong>Wrong Product:</strong> Received a different medicine than ordered</li>
            <li><strong>Expired Products:</strong> Medicine past expiry date at time of delivery</li>
          </ul>
        </section>

        <section>
          <h2>3. Non-Eligible Returns</h2>
          <p>The following items <strong>cannot</strong> be returned or refunded:</p>
          <ul>
            <li>Medicines that have been opened or used</li>
            <li>Items with no quality issues (change of mind, ordered wrong medicine, etc.)</li>
            <li>Products without original packaging</li>
            <li>Items returned after 48 hours of delivery</li>
          </ul>
        </section>

        <section>
          <h2>4. Return Process</h2>
          <p>To request a return:</p>
          <ol>
            <li><strong>Contact us immediately</strong> at +91 74284 44970 or hi@janaushadhi.oriz.in</li>
            <li>Provide your order ID and details of the issue</li>
            <li>Share photos of the product (if applicable)</li>
            <li>Bring the item to our store or arrange pickup (we'll guide you)</li>
          </ol>
        </section>

        <section>
          <h2>5. Refund Options</h2>
          <p>Depending on the situation, we may offer:</p>
          <ul>
            <li><strong>Replacement:</strong> Exchange for identical medicine (preferred)</li>
            <li><strong>Store Credit:</strong> Credit note for future purchases</li>
            <li><strong>Refund:</strong> Cash refund for paid orders (rare)</li>
          </ul>
          <p>
            Refunds are processed within 3-7 business days after approval.
          </p>
        </section>

        <section>
          <h2>6. Price on Request Items</h2>
          <p>
            For items marked "Price on Request", the final price will be confirmed at order
            confirmation. Refunds are not available once the order is placed and payment made,
            unless the product is damaged/defective.
          </p>
        </section>

        <section>
          <h2>7. Prescription Medicines</h2>
          <p>
            Medicines requiring prescriptions are assumed to be sold with valid prescription.
            No returns accepted once dispensed, even if unused, unless expired or damaged.
          </p>
        </section>

        <section>
          <h2>8. Shipping & Delivery Issues</h2>
          <p>
            If your order is lost, damaged in transit, or not delivered:
          </p>
          <ul>
            <li>Report within 24 hours of expected delivery</li>
            <li>We will investigate and either redeliver or refund</li>
            <li>Refund timeline depends on investigation outcome</li>
          </ul>
        </section>

        <section>
          <h2>9. Contact Us</h2>
          <p>
            For return/refund queries:
          </p>
          <ul>
            <li><strong>Phone:</strong> <a href="tel:+917428449707">+91 74284 44970</a></li>
            <li><strong>Email:</strong> <a href="mailto:hi@janaushadhi.oriz.in">hi@janaushadhi.oriz.in</a></li>
            <li><strong>Address:</strong> Plot #448, Niladri Vihar, Lane 5, Sector 5, Chandrasekharpur, Bhubaneswar</li>
          </ul>
        </section>
      </article>
    </div>
  </main>

  <style is:global>
    .legal-page {
      padding: var(--space-8) 0 var(--space-16);
    }

    .legal-content {
      max-width: 800px;
      margin: 0 auto;
      background-color: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-8);
    }

    .legal-header {
      margin-bottom: var(--space-8);
      padding-bottom: var(--space-6);
      border-bottom: 1px solid var(--color-border);
    }

    .legal-header h1 {
      font-size: var(--text-3xl);
      margin-bottom: var(--space-2);
    }

    .last-updated {
      color: var(--color-text-secondary);
      font-size: var(--text-sm);
    }

    section {
      margin-bottom: var(--space-8);
    }

    h2 {
      font-size: var(--text-xl);
      margin-bottom: var(--space-4);
      color: var(--color-primary-600);
    }

    p {
      margin-bottom: var(--space-4);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
    }

    ul, ol {
      margin-bottom: var(--space-4);
      padding-left: var(--space-6);
    }

    li {
      margin-bottom: var(--space-2);
    }

    a {
      color: var(--color-primary-600);
    }
  </style>
</BaseLayout>
