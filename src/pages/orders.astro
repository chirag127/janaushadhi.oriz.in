---
// src/pages/orders.astro
// Order history page with Firestore integration

import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Order History | Janaushadhi Store';
const description = 'View your order history and track current orders.';

// SSR-safe auth check - default to false on server
let isAuthenticated = false;
if (typeof window !== 'undefined') {
  // Client-side only - will be updated by script
  isAuthenticated = false;
}
---

<BaseLayout title={title} description={description} url="/orders">
  <main class="orders-page">
    <div class="container">
      <header class="page-header">
        <h1>Order History</h1>
        <p class="lead">Track and manage your orders</p>
      </header>

      {/* Auth required notice */}
      {!isAuthenticated && (
        <div class="auth-required">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <h2>Authentication Required</h2>
          <p>Please sign in to view your order history.</p>
          <button class="btn btn-primary" onclick="window.location.href = '/'">Sign In</button>
        </div>
      )}

      {isAuthenticated && (
        <div class="orders-content">
          {/* Orders will be loaded from Firestore */}
          <div id="orders-list" class="orders-list">
            <!-- Populated by JS -->
          </div>
        </div>
      )}
    </div>
  </main>

  <script is:client>
    import { auth, db, collection, query, where, orderBy, onSnapshot } from '../lib/firebase';

    // Check auth state
    const user = auth.currentUser;

    if (!user) {
      // Show sign-in prompt
      document.querySelector('.auth-required')?.classList.add('visible');
    } else {
      // Load orders from Firestore
      const ordersRef = collection(db, 'orders');
      const q = query(
        ordersRef,
        where('userId', '==', user.uid),
        orderBy('createdAt', 'desc')
      );

      const unsubscribe = onSnapshot(q, (snapshot) => {
        const orders = snapshot.docs.map(doc => ({
          id: doc.id,
          ...doc.data()
        }));

        renderOrders(orders);
      }, (error) => {
        console.error('Orders fetch error:', error);
        document.getElementById('orders-list').innerHTML = `
          <div class="error-message">
            Failed to load orders. Please try again.
          </div>
        `;
      });

      function renderOrders(orders) {
        const container = document.getElementById('orders-list');

        if (orders.length === 0) {
          container.innerHTML = `
            <div class="empty-orders">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2H10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2z"/>
                <path d="M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/>
              </svg>
              <h3>No orders yet</h3>
              <p>Start shopping to place your first order!</p>
              <a href="/medicines" class="btn btn-primary">Browse Medicines</a>
            </div>
          `;
          return;
        }

        container.innerHTML = orders.map(order => `
          <div class="order-card" data-order-id="${order.id}">
            <div class="order-header">
              <div>
                <span class="order-id">Order #${order.orderId}</span>
                <span class="order-date">${new Date(order.createdAt?.toDate?.() || order.orderDate).toLocaleDateString()}</span>
              </div>
              <span class="order-status status-${order.status?.toLowerCase() || 'pending'}">
                ${order.status || 'Pending'}
              </span>
            </div>

            <div class="order-body">
              <div class="order-items">
                ${order.items?.map((item: any) => `
                  <div class="order-item">
                    <span>${item.medicine?.genericName || item.slug}</span>
                    <span>Qty: ${item.quantity}</span>
                  </div>
                `).join('')}
              </div>

              <div class="order-summary">
                <div class="summary-row">
                  <span>Items</span>
                  <span>${order.items?.length || 0}</span>
                </div>
                <div class="summary-row total">
                  <span>Total</span>
                  <span>₹${order.total?.toFixed(2) || '0.00'}</span>
                </div>
              </div>
            </div>

            <div class="order-footer">
              <div class="order-details">
                <p><strong>Type:</strong> ${order.orderType === 'pickup' ? 'Store Pickup' : 'Cash on Delivery'}</p>
                <p><strong>Address:</strong> ${order.address}</p>
                <p><strong>Phone:</strong> ${order.phone}</p>
              </div>
              ${order.prescription && `
                <div class="prescription-link">
                  <a href="${order.prescription}" target="_blank">View Prescription</a>
                </div>
              `}
            </div>
          </div>
        `).join('');
      }
    }
  </script>

  <style is:global>
    .orders-page {
      padding: var(--space-8) 0 var(--space-16);
    }

    .auth-required {
      text-align: center;
      padding: var(--space-16);
      max-width: 500px;
      margin: 0 auto;
    }

    .auth-required svg {
      color: var(--color-text-tertiary);
      margin-bottom: var(--space-6);
    }

    .auth-required h2 {
      margin-bottom: var(--space-2);
    }

    .auth-required p {
      margin-bottom: var(--space-6);
    }

    /* Orders List */
    .orders-list {
      display: grid;
      gap: var(--space-6);
    }

    .order-card {
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      overflow: hidden;
    }

    .order-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--space-4) var(--space-6);
      background: var(--color-grey-50);
      border-bottom: 1px solid var(--color-border);
    }

    [data-theme="dark"] .order-header {
      background: var(--color-grey-800);
    }

    .order-id {
      font-weight: var(--font-bold);
      margin-right: var(--space-4);
    }

    .order-date {
      color: var(--color-text-tertiary);
      font-size: var(--text-sm);
    }

    .order-status {
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-full);
      font-size: var(--text-xs);
      font-weight: var(--font-semibold);
      text-transform: uppercase;
    }

    .status-pending {
      background: var(--color-warning-light);
      color: var(--color-warning-dark);
    }

    .status-confirmed,
    .status-processing {
      background: var(--color-info-light);
      color: var(--color-info-dark);
    }

    .status-completed {
      background: var(--color-success-light);
      color: var(--color-success-dark);
    }

    .status-cancelled {
      background: var(--color-error-light);
      color: var(--color-error-dark);
    }

    .order-body {
      padding: var(--space-6);
    }

    .order-items {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      margin-bottom: var(--space-4);
    }

    .order-item {
      display: flex;
      justify-content: space-between;
      padding: var(--space-2);
      border-bottom: 1px solid var(--color-border);
    }

    .order-item:last-child {
      border-bottom: none;
    }

    .order-summary {
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-border);
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: var(--space-2);
    }

    .summary-row.total {
      font-size: var(--text-lg);
      font-weight: var(--font-bold);
      margin-top: var(--space-2);
    }

    .order-footer {
      padding: var(--space-4) var(--space-6);
      background: var(--color-grey-50);
      border-top: 1px solid var(--color-border);
    }

    [data-theme="dark"] .order-footer {
      background: var(--color-grey-800);
    }

    .order-details p {
      margin-bottom: var(--space-1);
      font-size: var(--text-sm);
    }

    .empty-orders {
      text-align: center;
      padding: var(--space-16);
      color: var(--color-text-secondary);
    }

    .empty-orders svg {
      margin-bottom: var(--space-6);
      opacity: 0.5;
    }

    .empty-orders h3 {
      margin-bottom: var(--space-2);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-3) var(--space-6);
      background: var(--color-primary-600);
      color: white;
      border-radius: var(--radius-lg);
      text-decoration: none;
      font-weight: var(--font-medium);
    }

    .btn:hover {
      background: var(--color-primary-500);
    }
  </style>
</BaseLayout>
