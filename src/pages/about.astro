---
// src/pages/about.astro
// About Us page

import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About Us | Chirag Singhal\'s Janaushadhi Kendra | Janaushadhi Store';
const description = 'Learn about Chirag Singhal\'s Jan Aushadhi Kendra in Bhubaneswar. Your trusted source for affordable generic medicines.';
---

<BaseLayout title={title} description={description} url="/about">
  <main class="about-page">
    <div class="container">
      <header class="page-header">
        <h1>About Us</h1>
      </header>

      <div class="about-content">
        <section class="about-section">
          <h2>Chirag Singhal's Jan Aushadhi Kendra</h2>
          <p class="lead">
            Your trusted neighborhood pharmacy in Chandrasekharpur, Bhubaneswar.
            We are proud to be an authorized retailer of Janaushadhi generic medicines,
            offering quality healthcare products at affordable prices.
          </p>
        </section>

        <section class="about-section">
          <div class="about-grid">
            <div class="about-card">
              <h3>Our Mission</h3>
              <p>
                To make quality generic medicines accessible and affordable to every citizen,
                supporting the Government of India's Jan Aushadhi initiative.
              </p>
            </div>

            <div class="about-card">
              <h3>Quality Assurance</h3>
              <p>
                All medicines are sourced directly from BPPI-approved manufacturers.
                Every product meets stringent quality standards.
              </p>
            </div>

            <div class="about-card">
              <h3>Customer First</h3>
              <p>
                We prioritize your health needs with 24/7 service, competitive pricing,
                and knowledgeable staff ready to assist you.
              </p>
            </div>

            <div class="about-card">
              <h3>Community Trust</h3>
              <p>
                Serving the Chandrasekharpur community with integrity and care.
                We're more than a pharmacy - we're your health partner.
              </p>
            </div>
          </div>
        </section>

        <section class="about-section store-highlight">
          <div class="store-details">
            <h2>Store Information</h2>
            <div class="details-list">
              <div class="detail-item">
                <strong>Store Name:</strong><br/>
                Chirag Singhal's Jan Aushadhi Kendra
              </div>
              <div class="detail-item">
                <strong>Address:</strong><br/>
                Plot #448, Niladri Vihar, Lane 5, Sector 5<br/>
                Chandrasekharpur, Bhubaneswar<br/>
                Odisha - 751021
              </div>
              <div class="detail-item">
                <strong>Phone:</strong><br/>
                <a href="tel:+917428449707">+91 74284 44970</a>
              </div>
              <div class="detail-item">
                <strong>Email:</strong><br/>
                <a href="mailto:hi@janaushadhi.oriz.in">hi@janaushadhi.oriz.in</a>
              </div>
              <div class="detail-item">
                <strong>Working Hours:</strong><br/>
                24 hours, 7 days a week
              </div>
            </div>
          </div>
        </section>

        <section class="about-section disclaimer-note">
          <div class="disclaimer-box">
            <h3>Unofficial Website Notice</h3>
            <p>
              <strong>Important:</strong> This website is an independent, unofficial platform
              operated by Chirag Singhal. It is <strong>not affiliated</strong> with the
              Government of India, BPPI (Bureau of Pharma PSUs of India), or the official
              Janaushadhi programme.
            </p>
            <p>
              For official information about Janaushadhi, please visit the government portal:
              <a href="https://janaushadhi.gov.in" target="_blank" rel="noopener">
                janaushadhi.gov.in
              </a>
            </p>
          </div>
        </section>
      </div>
    </div>
  </main>

  <style is:global>
    .about-page {
      padding: var(--space-8) 0 var(--space-16);
    }

    .about-content {
      max-width: 800px;
    }

    .about-section {
      margin-bottom: var(--space-12);
    }

    .about-section h2 {
      font-size: var(--text-2xl);
      margin-bottom: var(--space-4);
      padding-bottom: var(--space-2);
      border-bottom: 2px solid var(--color-primary-500);
      display: inline-block;
    }

    .lead {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
    }

    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--space-6);
    }

    .about-card {
      padding: var(--space-6);
      background-color: var(--color-bg-secondary);
      border-radius: var(--radius-xl);
    }

    .about-card h3 {
      font-size: var(--text-lg);
      margin-bottom: var(--space-3);
      color: var(--color-primary-600);
    }

    .about-card p {
      font-size: var(--text-base);
      color: var(--color-text-secondary);
      line-height: var(--leading-relaxed);
    }

    .store-details {
      padding: var(--space-6);
      background-color: var(--color-grey-50);
      border-radius: var(--radius-xl);
    }

    [data-theme="dark"] .store-details {
      background-color: var(--color-grey-800);
    }

    .details-list {
      display: grid;
      gap: var(--space-4);
      margin-top: var(--space-4);
    }

    .detail-item {
      padding: var(--space-3);
      background-color: var(--color-bg-primary);
      border-radius: var(--radius-md);
      border-left: 4px solid var(--color-primary-500);
    }

    .detail-item a {
      color: var(--color-primary-600);
    }

    .disclaimer-box {
      padding: var(--space-6);
      background-color: var(--color-warning-light);
      border: 1px solid var(--color-warning);
      border-radius: var(--radius-xl);
    }

    [data-theme="dark"] .disclaimer-box {
      background-color: rgba(255, 193, 7, 0.15);
    }

    .disclaimer-box h3 {
      color: var(--color-warning-dark);
      margin-bottom: var(--space-2);
    }

    .disclaimer-box p {
      font-size: var(--text-sm);
      color: var(--color-warning-dark);
      line-height: var(--leading-relaxed);
    }

    .disclaimer-box a {
      color: var(--color-warning-dark);
      text-decoration: underline;
    }
  </style>
</BaseLayout>
